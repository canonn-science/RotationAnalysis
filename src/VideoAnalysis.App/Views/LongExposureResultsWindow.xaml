<Window x:Class="VideoAnalysis.App.Views.LongExposureResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/canonn.ico"
        Title="Long Exposure Results" Height="720" Width="980"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a variation to preview, then save it or save all of them." FontSize="16"
                   FontWeight="SemiBold" Foreground="{StaticResource CanonnAccentBrush}" Margin="0,0,0,12"/>

        <ListBox x:Name="VariantList" Grid.Row="1" SelectionMode="Single"
                 Background="Transparent" BorderThickness="0"
                 SelectionChanged="VariantList_SelectionChanged">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1"
                            Margin="6" Padding="4">
                        <StackPanel>
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" Height="150"/>
                            <TextBlock Text="{Binding DisplayName}" HorizontalAlignment="Center" Margin="0,6,0,2"
                                       Foreground="{StaticResource CanonnTextBrightBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="16,8" Margin="0,0,8,0" Click="CloseButton_Click"/>
            <Button x:Name="SaveSelectedButton" Content="Save Selected…" Padding="16,8" Margin="0,0,8,0"
                    Click="SaveSelectedButton_Click"/>
            <Button Content="Save All…" Padding="16,8"
                    Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                    Click="SaveAllButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
