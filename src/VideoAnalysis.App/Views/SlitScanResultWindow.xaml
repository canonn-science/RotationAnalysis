<Window x:Class="VideoAnalysis.App.Views.SlitScanResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Icon="/Assets/canonn.ico"
        Title="Slit Scan Result" Height="720" Width="980"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Preview the result, then save it." FontSize="16"
                   FontWeight="SemiBold" Foreground="{StaticResource CanonnAccentBrush}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="Black" BorderBrush="{StaticResource CanonnBorderBrush}" BorderThickness="1">
            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="4"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Padding="16,8" Margin="0,0,8,0" Click="CloseButton_Click"/>
            <Button Content="Save…" Padding="16,8"
                    Background="{StaticResource CanonnAccentBrush}" Foreground="White"
                    Click="SaveButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
